$C = "../../Common.ui";

$C.@PageOverlay {
    $C.@Container {
        Anchor: (Width: 950, Height: 650);

        #Title {
            $C.@Title {
                @Text = "REGIONS";
            }
        }

        #Content {
            LayoutMode: Top;

            // --- Barre de navigation ---
            Group #NavBar {
                Anchor: (Height: 45);
                Background: (Color: #16212f);
                LayoutMode: Left;
                Padding: (Horizontal: 10, Vertical: 5);

                Group #NavButtons {
                    FlexWeight: 1;
                    LayoutMode: Left;
                    Padding: (Vertical: 2);

                    TextButton #NavBtnHome {
                        Anchor: (Height: 36, Right: 8);
                        Padding: (Horizontal: 16);
                        Text: "Accueil";
                        Style: TextButtonStyle(
                            Default: (Background: #3a5a7a, LabelStyle: (FontSize: 13, TextColor: #ffffff, HorizontalAlignment: Center, VerticalAlignment: Center, RenderUppercase: true, RenderBold: true)),
                            Hovered: (Background: #4a6a8a, LabelStyle: (FontSize: 13, TextColor: #ffffff, HorizontalAlignment: Center, VerticalAlignment: Center, RenderUppercase: true, RenderBold: true)),
                            Sounds: $C.@ButtonSounds
                        );
                    }

                    TextButton #NavBtnList {
                        Anchor: (Height: 36, Right: 8);
                        Padding: (Horizontal: 16);
                        Text: "Liste";
                        Style: TextButtonStyle(
                            Default: (Background: #1f2d3f, LabelStyle: (FontSize: 13, TextColor: #96a9be, HorizontalAlignment: Center, VerticalAlignment: Center, RenderUppercase: true)),
                            Hovered: (Background: #2a3d4f, LabelStyle: (FontSize: 13, TextColor: #ffffff, HorizontalAlignment: Center, VerticalAlignment: Center, RenderUppercase: true)),
                            Sounds: $C.@ButtonSounds
                        );
                    }

                    TextButton #NavBtnCreate {
                        Anchor: (Height: 36);
                        Padding: (Horizontal: 16);
                        Text: "Creer";
                        Style: TextButtonStyle(
                            Default: (Background: #1f2d3f, LabelStyle: (FontSize: 13, TextColor: #96a9be, HorizontalAlignment: Center, VerticalAlignment: Center, RenderUppercase: true)),
                            Hovered: (Background: #2a3d4f, LabelStyle: (FontSize: 13, TextColor: #ffffff, HorizontalAlignment: Center, VerticalAlignment: Center, RenderUppercase: true)),
                            Sounds: $C.@ButtonSounds
                        );
                    }
                }

                TextButton #CloseButton {
                    Anchor: (Width: 40, Height: 36);
                    Text: "X";
                    Style: TextButtonStyle(
                        Default: (Background: #2a1a1a, LabelStyle: (FontSize: 16, TextColor: #ff4444, HorizontalAlignment: Center, VerticalAlignment: Center, RenderBold: true)),
                        Hovered: (Background: #3a2a2a, LabelStyle: (FontSize: 16, TextColor: #ff6666, HorizontalAlignment: Center, VerticalAlignment: Center, RenderBold: true)),
                        Sounds: $C.@ButtonSounds
                    );
                }
            }

            // ========================================================
            // PAGE: ACCUEIL
            // ========================================================
            Group #PageHome {
                FlexWeight: 1;
                LayoutMode: Top;
                Padding: (Full: 15);

                Label {
                    Text: "Gestion des Regions";
                    Anchor: (Height: 40);
                    Style: (FontSize: 22, TextColor: #ffd700, RenderBold: true, HorizontalAlignment: Center);
                }

                Label {
                    Text: "Creez et gerez vos regions protegees";
                    Anchor: (Height: 25);
                    Style: (FontSize: 13, TextColor: #96a9be, HorizontalAlignment: Center);
                }

                Group #QuickStats {
                    Anchor: (Height: 120, Top: 20);
                    LayoutMode: Left;

                    Group {
                        FlexWeight: 1;
                        Background: (Color: #151d28);
                        Padding: (Full: 15);
                        LayoutMode: Top;

                        Label { Text: "Regions"; Anchor: (Height: 22); Style: (FontSize: 13, TextColor: #ffd700, RenderBold: true); }
                        Label #StatRegionCount { Text: "0"; Anchor: (Height: 35); Style: (FontSize: 28, TextColor: #ffffff, RenderBold: true); }
                        Label { Text: "dans ce monde"; Anchor: (Height: 18); Style: (FontSize: 11, TextColor: #808080); }
                    }

                    Group { Anchor: (Width: 12); }

                    Group {
                        FlexWeight: 1;
                        Background: (Color: #151d28);
                        Padding: (Full: 15);
                        LayoutMode: Top;

                        Label { Text: "Vos regions"; Anchor: (Height: 22); Style: (FontSize: 13, TextColor: #00bfff, RenderBold: true); }
                        Label #StatMyRegionCount { Text: "0"; Anchor: (Height: 35); Style: (FontSize: 28, TextColor: #ffffff, RenderBold: true); }
                        Label { Text: "possedees"; Anchor: (Height: 18); Style: (FontSize: 11, TextColor: #808080); }
                    }

                    Group { Anchor: (Width: 12); }

                    Group {
                        FlexWeight: 1;
                        Background: (Color: #151d28);
                        Padding: (Full: 15);
                        LayoutMode: Top;

                        Label { Text: "Protection"; Anchor: (Height: 22); Style: (FontSize: 13, TextColor: #00ff7f, RenderBold: true); }
                        Label #StatProtectedBlocks { Text: "0"; Anchor: (Height: 35); Style: (FontSize: 28, TextColor: #ffffff, RenderBold: true); }
                        Label { Text: "blocs proteges"; Anchor: (Height: 18); Style: (FontSize: 11, TextColor: #808080); }
                    }
                }

                // === REGION GLOBALE ===
                Group #GlobalRegionBox {
                    Anchor: (Height: 100, Top: 20);
                    Background: (Color: #1a2535);
                    Padding: (Full: 15);
                    LayoutMode: Left;

                    Group {
                        FlexWeight: 1;
                        LayoutMode: Top;

                        Label { Text: "Region Globale"; Anchor: (Height: 24); Style: (FontSize: 15, TextColor: #ffd700, RenderBold: true); }
                        Label #GlobalRegionStatus { Text: "Non configuree"; Anchor: (Height: 20); Style: (FontSize: 12, TextColor: #808080); }
                        Label #GlobalRegionInfo { Text: "Couvre tout le monde avec priorite tres basse"; Anchor: (Height: 18); Style: (FontSize: 10, TextColor: #606060); }
                    }

                    Group {
                        Anchor: (Width: 180);
                        LayoutMode: Top;
                        Padding: (Left: 10);

                        TextButton #BtnCreateGlobal {
                            Anchor: (Height: 36);
                            Text: "CREER GLOBAL";
                            Style: TextButtonStyle(
                                Default: (Background: #5f5f2a, LabelStyle: (FontSize: 12, TextColor: #ffffff, HorizontalAlignment: Center, VerticalAlignment: Center, RenderBold: true)),
                                Hovered: (Background: #6f6f3a, LabelStyle: (FontSize: 12, TextColor: #ffffff, HorizontalAlignment: Center, VerticalAlignment: Center, RenderBold: true)),
                                Sounds: $C.@ButtonSounds
                            );
                        }

                        TextButton #BtnEditGlobal {
                            Anchor: (Height: 36);
                            Text: "GERER GLOBAL";
                            Visible: false;
                            Style: TextButtonStyle(
                                Default: (Background: #2a5a5a, LabelStyle: (FontSize: 12, TextColor: #ffffff, HorizontalAlignment: Center, VerticalAlignment: Center, RenderBold: true)),
                                Hovered: (Background: #3a6a6a, LabelStyle: (FontSize: 12, TextColor: #ffffff, HorizontalAlignment: Center, VerticalAlignment: Center, RenderBold: true)),
                                Sounds: $C.@ButtonSounds
                            );
                        }
                    }
                }
            }

            // ========================================================
            // PAGE: LISTE DES REGIONS
            // ========================================================
            Group #PageList {
                FlexWeight: 1;
                LayoutMode: Top;
                Padding: (Full: 15);
                Visible: false;

                Label {
                    Text: "Liste des regions";
                    Anchor: (Height: 35);
                    Style: (FontSize: 18, TextColor: #ffd700, RenderBold: true);
                }

                Group #RegionsList {
                    FlexWeight: 1;
                    Background: (Color: #0a0f17);
                    Padding: (Full: 8);
                    ScrollbarStyle: $C.@DefaultScrollbarStyle;
                    LayoutMode: TopScrolling;
                }
            }

            // ========================================================
            // PAGE: CREER UNE REGION
            // ========================================================
            Group #PageCreate {
                FlexWeight: 1;
                LayoutMode: Top;
                Padding: (Horizontal: 100, Vertical: 15);
                Visible: false;

                Label {
                    Text: "Creer une nouvelle region";
                    Anchor: (Height: 50);
                    Style: (FontSize: 20, TextColor: #ffd700, RenderBold: true, HorizontalAlignment: Center);
                }

                Group #CreateForm {
                    Anchor: (Height: 370, Top: 15);
                    LayoutMode: Top;
                    Background: (Color: #151d28);
                    Padding: (Full: 15);

                    Label { Text: "Nom de la region"; Anchor: (Height: 25); Style: (FontSize: 13, TextColor: #96a9be, RenderBold: true); }

                    $C.@TextField #InputRegionName {
                        Anchor: (Height: 40);
                        PlaceholderText: "Entrez un nom unique";
                    }

                    // === TOGGLE FORME ===
                    Label { Text: "Type de forme"; Anchor: (Height: 25, Top: 15); Style: (FontSize: 13, TextColor: #96a9be, RenderBold: true); }

                    Group #ShapeToggle {
                        Anchor: (Height: 40);
                        LayoutMode: Left;

                        Button #BtnShapeCuboid {
                            FlexWeight: 1;
                            Anchor: (Height: 36);
                            Background: (Color: #2a5a2a);
                            Label #LblShapeCuboid { Text: "CUBOID"; Style: (FontSize: 12, TextColor: #ffffff, HorizontalAlignment: Center, VerticalAlignment: Center, RenderBold: true); }
                        }

                        Group { Anchor: (Width: 8); }

                        Button #BtnShapeCylinder {
                            FlexWeight: 1;
                            Anchor: (Height: 36);
                            Background: (Color: #1f2d3f);
                            Label #LblShapeCylinder { Text: "CYLINDRE"; Style: (FontSize: 12, TextColor: #96a9be, HorizontalAlignment: Center, VerticalAlignment: Center); }
                        }
                    }

                    // === OPTIONS CYLINDRE (masque par defaut) ===
                    Group #CylinderOptions {
                        Anchor: (Height: 50, Top: 10);
                        LayoutMode: Left;
                        Visible: false;

                        Group {
                            FlexWeight: 1;
                            LayoutMode: Top;

                            Label { Text: "Rayon"; Anchor: (Height: 18); Style: (FontSize: 11, TextColor: #808080); }
                            $C.@NumberField #InputCylinderRadius {
                                Anchor: (Height: 32);
                                Value: 10;
                            }
                        }

                        Group { Anchor: (Width: 10); }

                        Group {
                            FlexWeight: 1;
                            LayoutMode: Top;

                            Label { Text: "Hauteur"; Anchor: (Height: 18); Style: (FontSize: 11, TextColor: #808080); }
                            $C.@NumberField #InputCylinderHeight {
                                Anchor: (Height: 32);
                                Value: 20;
                            }
                        }
                    }

                    Label { Text: "Priorite"; Anchor: (Height: 25, Top: 15); Style: (FontSize: 13, TextColor: #96a9be, RenderBold: true); }

                    Group {
                        Anchor: (Height: 40);
                        LayoutMode: Left;

                        $C.@NumberField #InputRegionPriority {
                            FlexWeight: 1;
                            Anchor: (Height: 38);
                            Value: 0;
                        }

                        Label { Anchor: (Width: 200, Left: 10); Text: "Plus haut = plus prioritaire"; Style: (FontSize: 11, TextColor: #808080, VerticalAlignment: Center); }
                    }

                    Group #SelectionInfo {
                        Anchor: (Height: 90, Top: 15);
                        LayoutMode: Top;
                        Background: (Color: #0a0f17);
                        Padding: (Full: 12);

                        Label #SelectionLabel { Text: "Selection actuelle (cuboid)"; Anchor: (Height: 24); Style: (FontSize: 13, TextColor: #00bfff, RenderBold: true); }
                        Label #SelectionCoords { Text: "Aucune selection - utilisez /pos1 et /pos2"; Anchor: (Height: 22); Style: (FontSize: 12, TextColor: #808080); }
                        Label #SelectionVolume { Text: ""; Anchor: (Height: 22); Style: (FontSize: 12, TextColor: #4a8f4a); }
                    }
                }

                Group #CreateButtons {
                    Anchor: (Height: 50, Top: 25);
                    LayoutMode: Left;

                    $C.@SecondaryTextButton #BtnCancelCreate {
                        FlexWeight: 1;
                        Anchor: (Height: 45);
                        Text: "ANNULER";
                    }

                    Group { Anchor: (Width: 20); }

                    $C.@TextButton #BtnConfirmCreate {
                        FlexWeight: 1;
                        Anchor: (Height: 45);
                        Text: "CREER LA REGION";
                    }
                }
            }

            // ========================================================
            // PAGE: EDITEUR DE REGION
            // ========================================================
            Group #PageEditor {
                FlexWeight: 1;
                LayoutMode: Left;
                Padding: (Full: 15);
                Visible: false;

                // --- Panneau gauche ---
                Group #EditorLeftPanel {
                    Anchor: (Width: 300);
                    LayoutMode: Top;
                    Padding: (Right: 15);

                    Label #EditorRegionName { Text: "Region"; Anchor: (Height: 35); Style: (FontSize: 18, TextColor: #ffd700, RenderBold: true); }

                    Group #EditorInfoBox {
                        Anchor: (Height: 90);
                        Background: (Color: #151d28);
                        Padding: (Full: 10);
                        LayoutMode: Top;

                        Label #EditorVolume { Text: "Volume: 0 blocs"; Anchor: (Height: 22); Style: (FontSize: 13, TextColor: #96a9be); }
                        Label #EditorOwners { Text: "Owners: 0"; Anchor: (Height: 22); Style: (FontSize: 13, TextColor: #96a9be); }
                        Label #EditorMembers { Text: "Membres: 0"; Anchor: (Height: 22); Style: (FontSize: 13, TextColor: #96a9be); }
                    }

                    Label #EditorPriority { Text: "Priorite: 0"; Anchor: (Height: 36, Top: 8); Style: (FontSize: 14, TextColor: #ffd700, RenderBold: true, VerticalAlignment: Center); }

                    Group {
                        Anchor: (Height: 36, Top: 10);
                        LayoutMode: Left;

                        TextButton #BtnTeleport {
                            FlexWeight: 1;
                            Anchor: (Height: 32);
                            Text: "TELEPORTER";
                            Style: TextButtonStyle(
                                Default: (Background: #2a5a2a, LabelStyle: (FontSize: 11, TextColor: #ffffff, HorizontalAlignment: Center, VerticalAlignment: Center, RenderBold: true)),
                                Hovered: (Background: #3a6a3a, LabelStyle: (FontSize: 11, TextColor: #ffffff, HorizontalAlignment: Center, VerticalAlignment: Center, RenderBold: true)),
                                Sounds: $C.@ButtonSounds
                            );
                        }

                        Group { Anchor: (Width: 6); }

                        TextButton #BtnShowZone {
                            FlexWeight: 1;
                            Anchor: (Height: 32);
                            Text: "BORDURES";
                            Style: TextButtonStyle(
                                Default: (Background: #3a4a5a, LabelStyle: (FontSize: 11, TextColor: #ffffff, HorizontalAlignment: Center, VerticalAlignment: Center, RenderBold: true)),
                                Hovered: (Background: #4a5a6a, LabelStyle: (FontSize: 11, TextColor: #ffffff, HorizontalAlignment: Center, VerticalAlignment: Center, RenderBold: true)),
                                Sounds: $C.@ButtonSounds
                            );
                        }
                    }

                    TextButton #BtnSetSelection {
                        Anchor: (Height: 32, Top: 6);
                        Text: "COPIER VERS SELECTION";
                        Style: TextButtonStyle(
                            Default: (Background: #5a4a2a, LabelStyle: (FontSize: 11, TextColor: #ffffff, HorizontalAlignment: Center, VerticalAlignment: Center, RenderBold: true)),
                            Hovered: (Background: #6a5a3a, LabelStyle: (FontSize: 11, TextColor: #ffffff, HorizontalAlignment: Center, VerticalAlignment: Center, RenderBold: true)),
                            Sounds: $C.@ButtonSounds
                        );
                    }

                    TextButton #BtnEditFlags {
                        Anchor: (Height: 40, Top: 10);
                        Text: "GERER LES FLAGS";
                        Style: TextButtonStyle(
                            Default: (Background: #2a4a6a, LabelStyle: (FontSize: 13, TextColor: #ffffff, HorizontalAlignment: Center, VerticalAlignment: Center, RenderBold: true)),
                            Hovered: (Background: #3a5a7a, LabelStyle: (FontSize: 13, TextColor: #ffffff, HorizontalAlignment: Center, VerticalAlignment: Center, RenderBold: true)),
                            Sounds: $C.@ButtonSounds
                        );
                    }

                    TextButton #BtnEditMembers {
                        Anchor: (Height: 40, Top: 8);
                        Text: "GERER LES MEMBRES";
                        Style: TextButtonStyle(
                            Default: (Background: #4a2a6a, LabelStyle: (FontSize: 13, TextColor: #ffffff, HorizontalAlignment: Center, VerticalAlignment: Center, RenderBold: true)),
                            Hovered: (Background: #5a3a7a, LabelStyle: (FontSize: 13, TextColor: #ffffff, HorizontalAlignment: Center, VerticalAlignment: Center, RenderBold: true)),
                            Sounds: $C.@ButtonSounds
                        );
                    }

                    TextButton #BtnDeleteRegion {
                        Anchor: (Height: 40, Top: 8);
                        Text: "SUPPRIMER";
                        Style: TextButtonStyle(
                            Default: (Background: #5a2a2a, LabelStyle: (FontSize: 13, TextColor: #ff6666, HorizontalAlignment: Center, VerticalAlignment: Center, RenderBold: true)),
                            Hovered: (Background: #6a3a3a, LabelStyle: (FontSize: 13, TextColor: #ff8888, HorizontalAlignment: Center, VerticalAlignment: Center, RenderBold: true)),
                            Sounds: $C.@ButtonSounds
                        );
                    }

                    Group #DeleteConfirmButtons {
                        Anchor: (Height: 40, Top: 8);
                        LayoutMode: Left;
                        Visible: false;

                        TextButton #BtnConfirmDelete {
                            FlexWeight: 1;
                            Anchor: (Height: 36);
                            Text: "CONFIRMER";
                            Style: TextButtonStyle(
                                Default: (Background: #8f2a2a, LabelStyle: (FontSize: 12, TextColor: #ffffff, HorizontalAlignment: Center, VerticalAlignment: Center, RenderBold: true)),
                                Hovered: (Background: #af3a3a, LabelStyle: (FontSize: 12, TextColor: #ffffff, HorizontalAlignment: Center, VerticalAlignment: Center, RenderBold: true)),
                                Sounds: $C.@ButtonSounds
                            );
                        }

                        Group { Anchor: (Width: 8); }

                        $C.@SecondaryTextButton #BtnCancelDelete {
                            FlexWeight: 1;
                            Anchor: (Height: 36);
                            Text: "ANNULER";
                        }
                    }

                    Group { FlexWeight: 1; }

                    $C.@SecondaryTextButton #BtnBackToList {
                        Anchor: (Height: 36);
                        Text: "RETOUR A LA LISTE";
                    }
                }

                Group {
                    Anchor: (Width: 2);
                    Background: (Color: #4a4a6a);
                }

                // --- Panneau droit - Flags actifs ---
                Group #EditorRightPanel {
                    FlexWeight: 1;
                    LayoutMode: Top;
                    Padding: (Left: 15);

                    Label { Text: "Flags actifs"; Anchor: (Height: 30); Style: (FontSize: 16, TextColor: #ffd700, RenderBold: true); }

                    Group #ActiveFlagsList {
                        FlexWeight: 1;
                        Background: (Color: #0a0f17);
                        Padding: (Full: 10);
                        ScrollbarStyle: $C.@DefaultScrollbarStyle;
                        LayoutMode: TopScrolling;
                    }
                }
            }

            // ========================================================
            // PAGE: GESTION DES FLAGS (avec onglets)
            // ========================================================
            Group #PageFlags {
                FlexWeight: 1;
                LayoutMode: Top;
                Padding: (Full: 15);
                Visible: false;

                // Header avec bouton retour et titre
                Group {
                    Anchor: (Height: 40);
                    LayoutMode: Left;

                    $C.@SecondaryTextButton #BtnBackFromFlags {
                        Anchor: (Width: 100, Height: 36);
                        Text: "< RETOUR";
                    }

                    Label #FlagsTitle { FlexWeight: 1; Text: "Flags"; Style: (FontSize: 18, TextColor: #ffd700, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); }

                    Label { Anchor: (Width: 100); Text: "Auto-save"; Style: (FontSize: 11, TextColor: #4a8f4a, HorizontalAlignment: Center, VerticalAlignment: Center); }
                }

                // === BARRE D'ONGLETS ===
                Group #FlagsTabBar {
                    Anchor: (Height: 45, Top: 10);
                    LayoutMode: Left;
                    Background: (Color: #16212f);
                    Padding: (Horizontal: 5, Vertical: 5);

                    TextButton #TabRegion {
                        FlexWeight: 1;
                        Anchor: (Height: 35);
                        Text: "REGION";
                        Style: TextButtonStyle(
                            Default: (Background: #3a5a7a, LabelStyle: (FontSize: 12, TextColor: #ffffff, HorizontalAlignment: Center, VerticalAlignment: Center, RenderBold: true, RenderUppercase: true)),
                            Hovered: (Background: #4a6a8a, LabelStyle: (FontSize: 12, TextColor: #ffffff, HorizontalAlignment: Center, VerticalAlignment: Center, RenderBold: true, RenderUppercase: true)),
                            Sounds: $C.@ButtonSounds
                        );
                    }

                    Group { Anchor: (Width: 5); }

                    TextButton #TabGroup {
                        FlexWeight: 1;
                        Anchor: (Height: 35);
                        Text: "GROUPE";
                        Style: TextButtonStyle(
                            Default: (Background: #1f2d3f, LabelStyle: (FontSize: 12, TextColor: #96a9be, HorizontalAlignment: Center, VerticalAlignment: Center, RenderUppercase: true)),
                            Hovered: (Background: #2a3d4f, LabelStyle: (FontSize: 12, TextColor: #ffffff, HorizontalAlignment: Center, VerticalAlignment: Center, RenderUppercase: true)),
                            Sounds: $C.@ButtonSounds
                        );
                    }

                    Group { Anchor: (Width: 5); }

                    TextButton #TabPlayer {
                        FlexWeight: 1;
                        Anchor: (Height: 35);
                        Text: "JOUEUR";
                        Style: TextButtonStyle(
                            Default: (Background: #1f2d3f, LabelStyle: (FontSize: 12, TextColor: #96a9be, HorizontalAlignment: Center, VerticalAlignment: Center, RenderUppercase: true)),
                            Hovered: (Background: #2a3d4f, LabelStyle: (FontSize: 12, TextColor: #ffffff, HorizontalAlignment: Center, VerticalAlignment: Center, RenderUppercase: true)),
                            Sounds: $C.@ButtonSounds
                        );
                    }
                }

                // === ONGLET REGION (flags de base) ===
                Group #TabContentRegion {
                    FlexWeight: 1;
                    LayoutMode: Top;
                    Anchor: (Top: 10);

                    Group #FlagsList {
                        FlexWeight: 1;
                        Background: (Color: #0a0f17);
                        Padding: (Full: 10);
                        ScrollbarStyle: $C.@DefaultScrollbarStyle;
                        LayoutMode: TopScrolling;
                    }
                }

                // === ONGLET GROUPE (overrides par rank) ===
                Group #TabContentGroup {
                    FlexWeight: 1;
                    LayoutMode: Top;
                    Anchor: (Top: 10);
                    Visible: false;

                    // Selecteur de groupe
                    Group #GroupSelector {
                        Anchor: (Height: 50);
                        LayoutMode: Left;
                        Background: (Color: #151d28);
                        Padding: (Full: 10);

                        Label { Anchor: (Width: 80); Text: "Groupe:"; Style: (FontSize: 13, TextColor: #96a9be, VerticalAlignment: Center); }

                        Group #RankButtonsContainer {
                            FlexWeight: 1;
                            LayoutMode: Left;
                            ScrollbarStyle: $C.@DefaultScrollbarStyle;
                        }
                    }

                    // Info du groupe selectionne
                    Group #SelectedGroupInfo {
                        Anchor: (Height: 35, Top: 5);
                        Background: (Color: #1a2a3a);
                        Padding: (Horizontal: 15, Vertical: 8);
                        Visible: false;

                        Label #SelectedGroupName { Text: ""; Style: (FontSize: 14, TextColor: #ffd700, VerticalAlignment: Center); }
                    }

                    // Liste des flags du groupe
                    Group #GroupFlagsList {
                        FlexWeight: 1;
                        Background: (Color: #0a0f17);
                        Padding: (Full: 10);
                        ScrollbarStyle: $C.@DefaultScrollbarStyle;
                        LayoutMode: TopScrolling;
                        Anchor: (Top: 10);
                    }
                }

                // === ONGLET JOUEUR (overrides par joueur) ===
                Group #TabContentPlayer {
                    FlexWeight: 1;
                    LayoutMode: Top;
                    Anchor: (Top: 10);
                    Visible: false;

                    // Recherche de joueur
                    Group #PlayerSelector {
                        Anchor: (Height: 50);
                        LayoutMode: Left;
                        Background: (Color: #151d28);
                        Padding: (Full: 10);

                        Label { Anchor: (Width: 80); Text: "Joueur:"; Style: (FontSize: 13, TextColor: #96a9be, VerticalAlignment: Center); }

                        $C.@TextField #InputPlayerSearch {
                            FlexWeight: 1;
                            Anchor: (Height: 34);
                            PlaceholderText: "Entrer un pseudo";
                        }

                        Group { Anchor: (Width: 10); }

                        TextButton #BtnSearchPlayer {
                            Anchor: (Width: 100, Height: 34);
                            Text: "CHERCHER";
                            Style: TextButtonStyle(
                                Default: (Background: #2a5a2a, LabelStyle: (FontSize: 11, TextColor: #ffffff, HorizontalAlignment: Center, VerticalAlignment: Center, RenderBold: true)),
                                Hovered: (Background: #3a6a3a, LabelStyle: (FontSize: 11, TextColor: #ffffff, HorizontalAlignment: Center, VerticalAlignment: Center, RenderBold: true)),
                                Sounds: $C.@ButtonSounds
                            );
                        }
                    }

                    // Info du joueur selectionne
                    Group #SelectedPlayerInfo {
                        Anchor: (Height: 40, Top: 5);
                        Background: (Color: #1a2a3a);
                        Padding: (Horizontal: 15, Vertical: 8);
                        Visible: false;
                        LayoutMode: Left;

                        Label #SelectedPlayerName { FlexWeight: 1; Text: ""; Style: (FontSize: 14, TextColor: #ffd700, VerticalAlignment: Center); }

                        TextButton #BtnClearPlayerSelection {
                            Anchor: (Width: 80, Height: 28);
                            Text: "EFFACER";
                            Style: TextButtonStyle(
                                Default: (Background: #5a2a2a, LabelStyle: (FontSize: 10, TextColor: #ff6666, HorizontalAlignment: Center, VerticalAlignment: Center)),
                                Hovered: (Background: #6a3a3a, LabelStyle: (FontSize: 10, TextColor: #ff8888, HorizontalAlignment: Center, VerticalAlignment: Center)),
                                Sounds: $C.@ButtonSounds
                            );
                        }
                    }

                    // Liste des flags du joueur
                    Group #PlayerFlagsList {
                        FlexWeight: 1;
                        Background: (Color: #0a0f17);
                        Padding: (Full: 10);
                        ScrollbarStyle: $C.@DefaultScrollbarStyle;
                        LayoutMode: TopScrolling;
                        Anchor: (Top: 10);
                    }
                }
            }

            // ========================================================
            // PAGE: GESTION DES MEMBRES
            // ========================================================
            Group #PageMembers {
                FlexWeight: 1;
                LayoutMode: Top;
                Padding: (Full: 15);
                Visible: false;

                Group {
                    Anchor: (Height: 40);
                    LayoutMode: Left;

                    $C.@SecondaryTextButton #BtnBackFromMembers {
                        Anchor: (Width: 100, Height: 36);
                        Text: "< RETOUR";
                    }

                    Label #MembersTitle { FlexWeight: 1; Text: "Membres"; Style: (FontSize: 18, TextColor: #ffd700, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); }
                }

                Group #AddMemberBox {
                    Anchor: (Height: 50, Top: 10);
                    Background: (Color: #151d28);
                    Padding: (Full: 8);
                    LayoutMode: Left;

                    $C.@TextField #InputMemberName {
                        FlexWeight: 1;
                        Anchor: (Height: 34);
                        PlaceholderText: "Entrer un pseudo";
                    }

                    Group { Anchor: (Width: 10); }

                    TextButton #BtnAddMember {
                        Anchor: (Width: 120, Height: 34);
                        Text: "+ MEMBRE";
                        Style: TextButtonStyle(
                            Default: (Background: #2a5a2a, LabelStyle: (FontSize: 12, TextColor: #ffffff, HorizontalAlignment: Center, VerticalAlignment: Center, RenderBold: true)),
                            Hovered: (Background: #3a6a3a, LabelStyle: (FontSize: 12, TextColor: #ffffff, HorizontalAlignment: Center, VerticalAlignment: Center, RenderBold: true)),
                            Sounds: $C.@ButtonSounds
                        );
                    }

                    Group { Anchor: (Width: 6); }

                    TextButton #BtnAddOwner {
                        Anchor: (Width: 120, Height: 34);
                        Text: "+ PROPRIO";
                        Style: TextButtonStyle(
                            Default: (Background: #5f5f2a, LabelStyle: (FontSize: 12, TextColor: #ffffff, HorizontalAlignment: Center, VerticalAlignment: Center, RenderBold: true)),
                            Hovered: (Background: #6f6f3a, LabelStyle: (FontSize: 12, TextColor: #ffffff, HorizontalAlignment: Center, VerticalAlignment: Center, RenderBold: true)),
                            Sounds: $C.@ButtonSounds
                        );
                    }
                }

                Group {
                    FlexWeight: 1;
                    LayoutMode: Left;
                    Anchor: (Top: 10);

                    Group {
                        FlexWeight: 1;
                        LayoutMode: Top;

                        Label { Text: "Proprietaires"; Anchor: (Height: 25); Style: (FontSize: 14, TextColor: #ffd700, RenderBold: true); }

                        Group #OwnersList {
                            FlexWeight: 1;
                            Background: (Color: #0a0f17);
                            Padding: (Full: 5);
                            ScrollbarStyle: $C.@DefaultScrollbarStyle;
                            LayoutMode: TopScrolling;
                        }
                    }

                    Group { Anchor: (Width: 10); }

                    Group {
                        FlexWeight: 1;
                        LayoutMode: Top;

                        Label { Text: "Membres"; Anchor: (Height: 25); Style: (FontSize: 14, TextColor: #00bfff, RenderBold: true); }

                        Group #MembersList {
                            FlexWeight: 1;
                            Background: (Color: #0a0f17);
                            Padding: (Full: 5);
                            ScrollbarStyle: $C.@DefaultScrollbarStyle;
                            LayoutMode: TopScrolling;
                        }
                    }
                }
            }
        }
    }
}
